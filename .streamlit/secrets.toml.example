# Copy to secrets.toml and fill in your Supabase credentials.
# Use the Supavisor (pooler) URL from Supabase → Project Settings → Database → Connection string → URI
# Transaction mode (port 6543) is recommended for Streamlit Cloud.
PORTAL_SLUG = "porciuncula_prefeitura"

[connections.postgresql]
url = "postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"
